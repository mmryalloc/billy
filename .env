# Application
APP_NAME=billy
APP_ENV=development       # development | staging | production
APP_PORT=8080
APP_BASE_URL=http://localhost:8080

# Database
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=billy_db
DB_SSL_MODE=disable
DB_MAX_CONNS=25
